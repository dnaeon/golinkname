-- a/a.go --
package a

import _ "unsafe"

// One-arg directive on a var with an initializer: the var-equivalent
// of Case 1 (function with body). The author owns the storage and is
// publishing it under its own canonical name for other packages to
// linkname-pull. Mirrors database/sql.drivers in the stdlib.
//
//go:linkname drivers
var drivers = make(map[string]int)

// Two-arg directive on a var with an initializer: Case 3 equivalent.
// The author owns the storage and is publishing it under a foreign
// linker name.
//
//go:linkname renamed example.com/m/b.target
var renamed = 42

// Same shape inside a var block.
var (
	//go:linkname blockPush example.com/m/b.blockPushTarget
	blockPush = []int{1, 2, 3}

	//go:linkname blockPull example.com/m/b.blockPullTarget
	blockPull []int
)
-- b/b.go --
package b

var target int
var blockPushTarget []int
var blockPullTarget []int
